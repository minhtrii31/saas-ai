NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb
MONGODB_URI=mongodb://127.0.0.1:27017/saas-ai
# Optional in development/test. Required in production.
# REDIS_URL=redis://127.0.0.1:6379

ACCESS_TOKEN_SECRET=replace-with-at-least-32-characters-for-local-dev
ACCESS_TOKEN_EXPIRES_IN=15m
JWT_ISSUER=saas-ai
JWT_AUDIENCE=saas-ai-api
REFRESH_TOKEN_COOKIE_NAME=refreshToken
REFRESH_TOKEN_EXPIRES_DAYS=7

# Local/demo auth limits. Production should use lower values documented in
# docs/08-deployment/deployment-planning.md.
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=300
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=900000
AUTH_REGISTER_RATE_LIMIT_MAX=300
AUTH_REFRESH_RATE_LIMIT_WINDOW_MS=900000
AUTH_REFRESH_RATE_LIMIT_MAX=600

# Fallback for account lifecycle auth endpoints and older deployments.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=300

AI_ROUTE_RATE_LIMIT_WINDOW_MS=60000
AI_ROUTE_RATE_LIMIT_MAX=10

UPLOAD_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CV_FOLDER=saas-ai/cvs

GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash
AI_REQUEST_TIMEOUT_MS=30000

CV_MAX_FILE_SIZE_BYTES=5242880
CV_MAX_PAGE_COUNT=5
CV_PARSE_TIMEOUT_MS=10000
CV_PARSED_TEXT_MAX_CHARACTERS=100000
CV_RETENTION_DAYS=30
CV_ANALYSIS_DAILY_LIMIT=5
JOB_DESCRIPTION_MAX_CHARACTERS=10000
CV_JOB_COMPARISON_DAILY_LIMIT=5
COVER_LETTER_DAILY_LIMIT=3

EMAIL_PROVIDER=console
EMAIL_FROM="SaaS AI <no-reply@example.local>"
RESEND_API_KEY=
