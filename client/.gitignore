# Environment files with local or production secrets.
.env
.env.*
!.env.example
!.env.*.example

# Dependencies and package manager internals.
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js output and local caches.
/.next/
/out/
/build/
/.turbo/
/.cache/

# Test output.
/coverage/
/playwright-report/
/test-results/

# TypeScript and generated framework files.
*.tsbuildinfo
next-env.d.ts

# Logs and diagnostics.
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local-only runtime files.
tmp/
temp/
*.local

# Secrets, certificates, and keys.
*.pem
*.key
*.crt
*.p12
*.pfx

# OS/editor noise.
.DS_Store
Thumbs.db
.idea/
.vscode/
